aws_region           = "us-east-1"
project_name         = "turn-based-game"
environment          = "dev"
frontend_bucket_name = "your-frontend-bucket-name"
cloudfront_distribution_id = "YOUR_DISTRIBUTION_ID"
frontend_waf_web_acl_arn  = null
frontend_cloudfront_enabled = true
frontend_origin_id = "frontend-s3-origin"
waiting_queue_table_name = "WaitingQueue"
matches_table_name       = "Matches"
matchmaking_lambda_name          = "matchmakingHandler"
matches_table_env_var_name       = "MATCHES_TABLE"
waiting_queue_table_env_var_name = "WAITING_QUEUE_TABLE"
matchmaking_lambda_package_path = "../../backend/matchmaking/matchmaking.zip"
matchmaking_lambda_role_arn = "arn:aws:iam::123456789012:role/service-role/your-lambda-role-name"
matchmaking_lambda_role_name = "matchmaking-lambda-role"
matchmaking_lambda_basic_policy_arn = "arn:aws:iam::123456789012:policy/service-role/your-lambda-basic-policy"
matchmaking_lambda_inline_policy_name = "MatchmakingDynamoPolicy"
api_gateway_name           = "your-http-api-name"
api_gateway_id             = "your-api-id"
api_gateway_integration_id = "your-integration-id"
api_gateway_cors_allow_origins = [
  "http://localhost:5173",
  "https://your-cloudfront-domain.cloudfront.net"
]
api_gateway_stage_name    = "$default"
api_gateway_execution_arn = "arn:aws:execute-api:us-east-1:123456789012:your-api-id"
api_gateway_authorizer_id = "your-authorizer-id"